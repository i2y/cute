# Cute test framework demo.
#
# `cute test examples/test_demo/test_demo.cute` discovers every test
# (compact `test fn name { ... }` and Mint-inspired `test "free form"`
# / `suite "X" { test "y" { ... } }`), runs them, and prints TAP-lite:
#
#   1..4
#   ok 1 - addition
#   ok 2 - compute / adds positive numbers
#   ok 3 - compute / handles zero divisor as zero
#   ok 4 - compute / multiplies and subtracts
#   # 4 passed, 0 failed
#
# A failed assertion (e.g. `assert_eq(2 + 2, 5)`) prints
# `not ok N - <name>: actual=4 expected=5 at <file>:<line>` and the
# binary exits non-zero.

fn compute(a: Float, op: String, b: Float) Float {
  if op == "+" { return a + b }
  if op == "-" { return a - b }
  if op == "*" { return a * b }
  if op == "/" {
    if b == 0.0 { return 0.0 }
    return a / b
  }
  b
}

# Compact form — name is an identifier. Still the right tool when the
# test does one thing and a snake_case-y name says it.

test fn addition {
  assert_eq(2 + 2, 4)
  assert_eq(0 + 0, 0)
  let n = 7
  assert_eq("n=#{n}", "n=7")
}

# Suite-grouped, free-form-string-named — readable in TAP output even
# when the test description has spaces, punctuation, or natural
# language. Display label is `<suite> / <test>`.

suite "compute" {
  test "adds positive numbers" {
    assert_eq(compute(3.0, "+", 4.0), 7.0)
  }

  test "handles zero divisor as zero" {
    assert_eq(compute(1.0, "/", 0.0), 0.0)
  }

  test "multiplies and subtracts" {
    assert_eq(compute(6.0, "*", 7.0), 42.0)
    assert_eq(compute(10.0, "-", 4.0), 6.0)
    assert_eq(compute(20.0, "/", 4.0), 5.0)
  }
}
