# Docker build-context exclusions. Without these, target/ alone
# would balloon the tarball to multiple GB and stall the build
# before any RUN step starts.
target/
.git/
.idea/
.vscode/

# Build artifacts inside example dirs (cute-built binaries +
# generated wrappers).
examples/*/run.sh
examples/*/.cs_resigned
examples/*/*.run.sh
examples/*/*.cs_resigned
# The example binary is the same name as its dir; we can't
# wildcard exactly, so list the most common .cute-build outputs.
examples/counter/counter
examples/counter_state/counter_state
examples/two_counters/two_counters
